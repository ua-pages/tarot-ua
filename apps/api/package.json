{
  "name": "@tarot/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start:dev": "nodemon --watch src --ext ts --exec \"ts-node --transpile-only src/main.ts\"",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "cross-env TS_NODE_PROJECT=tsconfig.spec.json jasmine --config=jasmine.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "gremlin": "^3.7.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/jasmine": "^5.1.5",
    "@types/node": "^22.8.6",
    "cross-env": "^7.0.3",
    "jasmine": "^5.3.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
